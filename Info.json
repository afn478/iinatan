{
  "name": "iinatan",
  "identifier": "com.afn478.iinatan",
  "version": "2.0.0",
  "author": {
    "name": "afn478"
  },
  "description": "Hover subtitles to see dictionary popups in IINA.",
  "entry": "main.js",
  "globalEntry": "global.js",
  "preferencesPage": "preferences.html",
  "helpPage": "README.md",
  "ghRepo": "afn478/iinatan",
  "ghVersion": 200,
  "preferenceDefaults": {
    "enabledByDefault": true,
    "hideNativeSubtitles": true,
    "audioAutoPlay": false,
    "audioSourcesJson": "[{\"url\":\"http://127.0.0.1:5050/?term={term}&reading={reading}\"}]",
    "ankiEnabled": false,
    "ankiConnectUrl": "http://127.0.0.1:8765",
    "ankiConnectTimeoutSeconds": 3,
    "ankiDeckName": "",
    "ankiModelName": "",
    "ankiFieldTemplatesJson": "{}",
    "ankiTags": "iinatan",
    "ankiAudioFormat": "mp3",
    "ankiAudioBitrateKbps": 96,
    "ankiImageQuality": 85,
    "ankiDuplicateCheck": true,
    "ankiDuplicateMode": "prevent",
    "ankiDuplicateScope": "deck",
    "ankiSentenceAudioPaddingMs": 250,
    "lookupLanguage": "ja",
    "fontScale": 1.0,
    "popupScale": 0.92,
    "popupMaxWidth": 440,
    "popupTheme": "inherit",
    "maxEntries": 3,
    "maxGlossesPerEntry": 4,
    "scanLength": 24,
    "hoverRequestTimeoutMs": 15000,
    "backendTimeoutMs": 30000,
    "importTimeoutMs": 1800000,
    "lowRamImport": true,
    "subtitlePollMs": 120,
    "popupMaxHeightVh": 34,
    "popupSubtitleGapPx": 34,
    "pauseWhilePopupVisible": true,
    "lookupTimeoutMs": 9000,
    "etymologyCollapseDefault": "collapsed",
    "wiktionaryEtymologyCollapseOverride": "collapsed",
    "customPopupCss": "",
    "debugLogEnabled": true,
    "debugLogVerbose": false,
    "directWorkerIpc": true,
    "fallbackToClientExec": true,
    "directIpcPollMs": 2,
    "workerIdleSleepMs": 2
  },
  "permissions": [
    "video-overlay",
    "network-request",
    "file-system",
    "show-osd",
    "show-alert"
  ],
  "allowedDomains": [
    "*"
  ]
}
